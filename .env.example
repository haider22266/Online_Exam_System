SECRET_KEY=replace-with-a-long-random-secret
FLASK_ENV=development
# Copy this file to .env and replace the placeholder with your own key.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# SQL Server with Windows Authentication and ODBC Driver 17.
DATABASE_URL=mssql+pyodbc://@DESKTOP-OH99USR/ExamAI?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# ODBC Driver 18 alternative:
# DATABASE_URL=mssql+pyodbc://@DESKTOP-OH99USR/ExamAI?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes&Encrypt=no
